{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/capabilities/layout,_N_T_/capabilities/page,_N_T_/capabilities"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/capabilities/__PAGE__",
    "/capabilities",
    "/_index",
    "/_head"
  ]
}