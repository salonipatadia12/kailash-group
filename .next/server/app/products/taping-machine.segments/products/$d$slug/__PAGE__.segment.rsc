e:["$","p",null,{"className":"pb-5 text-sm leading-relaxed","style":{"color":"#666666"},"children":"Yes. Our taping machines are designed to work with standard 48mm or 72mm wide BOPP tape rolls on a 76mm core — the same specification as the tape rolls we supply. This ensures consistent compatibility between your machine and tape."}]
f:["$","details","3",{"className":"group","style":{"borderBottom":"1px solid #e5e7eb"},"children":[["$","summary",null,{"className":"flex items-center justify-between gap-4 py-4 cursor-pointer select-none list-none","style":{"color":"#111111"},"children":[["$","span",null,{"className":"text-sm sm:text-base font-semibold pr-4","style":{"color":"#061553"},"children":"What maintenance does a taping machine require?"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180","style":{"color":"#f3cf2d"},"aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"pb-5 text-sm leading-relaxed","style":{"color":"#666666"},"children":"Taping machines are low-maintenance. Regular maintenance includes cleaning the tape path and roller to remove adhesive build-up, checking blade sharpness (the tape cutting blade), and lubricating moving parts as per the manufacturer guide. Most machines require a basic clean every 1–2 weeks depending on usage volume."}]]}]
10:["$","details","4",{"className":"group","style":{"borderBottom":"1px solid #e5e7eb"},"children":[["$","summary",null,{"className":"flex items-center justify-between gap-4 py-4 cursor-pointer select-none list-none","style":{"color":"#111111"},"children":[["$","span",null,{"className":"text-sm sm:text-base font-semibold pr-4","style":{"color":"#061553"},"children":"Do you provide after-sales support for the machines?"}],["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-chevron-down h-4 w-4 shrink-0 transition-transform duration-200 group-open:rotate-180","style":{"color":"#f3cf2d"},"aria-hidden":"true","children":[["$","path","qrunsl",{"d":"m6 9 6 6 6-6"}],"$undefined"]}]]}],["$","p",null,{"className":"pb-5 text-sm leading-relaxed","style":{"color":"#666666"},"children":"We assist with initial setup guidance and can advise on common operational issues. For major repairs, we can connect you with service technicians. Replacement parts (blades, rollers, springs) are available and can be sourced through us."}]]}]
